<script>
    const taggingSupportCheckbox = document.getElementById('tagging_support');
    const tagValueInput = document.getElementById('tag_value');
    const tagValueContainer = document.getElementById('tag_value_container');
    const tagPrefixAddon = tagValueInput.closest('.input-group').querySelector('.input-group-text');

    function updateTaggingFields() {
        const isEnabled = taggingSupportCheckbox.checked;
        tagValueInput.disabled = !isEnabled;
        if (isEnabled) {
            tagValueContainer.classList.remove('text-muted');
            tagPrefixAddon.classList.remove('text-muted');
            tagValueInput.setAttribute('required', 'required');
        } else {
            tagValueContainer.classList.add('text-muted');
            tagPrefixAddon.classList.add('text-muted');
            tagValueInput.removeAttribute('required');
        }
    }

    taggingSupportCheckbox.addEventListener('change', updateTaggingFields);
    updateTaggingFields();

    const providerSelect = document.getElementById('provider_key');
    const providerUserSelect = document.getElementById('provider_user_id');
    const discourseCredentials = document.getElementById('discourse_credentials');
    const transkribusCredentials = document.getElementById('transkribus_credentials');
    const configLink = <?= json_encode($module->getConfigLink(), JSON_THROW_ON_ERROR) ?>;

    function updateProviderFields() {
        const provider = providerSelect.value;
        discourseCredentials.hidden = provider !== 'discourse';
        transkribusCredentials.hidden = provider !== 'transkribus';
    }

    providerSelect.addEventListener('change', updateProviderFields);
    providerUserSelect.addEventListener('change', function () {
        const separator = configLink.includes('?') ? '&' : '?';
        location.href = configLink + separator + 'provider_user_id=' + encodeURIComponent(providerUserSelect.value) + '&provider_key=' + encodeURIComponent(providerSelect.value);
    });
    updateProviderFields();
</script>
