<?php

declare(strict_types=1);

//tbd: describe the meaning of the NOTE update strategy

/**
 * @var string $title
 * @var SourceTranscription $module
 * @var bool $runs_with_webtrees_version
 * @var string $default_note_strategy
 * @var array<string,string> $note_strategies
 * @var string $tiny_mde
 * @var string $tagging_support
 * @var string $tag_prefix
 * @var string $tag_value
 */

use Fisharebest\Webtrees\I18N;
use Hartenthaler\Webtrees\Module\SourceTranscription\SourceTranscription;

?>

<h2><?= e($title) ?></h2>
<?php if (!$runs_with_webtrees_version) : ?>
    <div class="alert alert-danger">
        <?= I18N::translate('This module can only be used with a webtrees version greater or equal than %s.', SourceTranscription::MINIMUM_WEBTREES_VERSION) ?>
    </div>
<?php endif ?>

<form method="post" action="<?= e($module->getConfigLink()) ?>">
    <?= csrf_field() ?>
    <input type="hidden" name="save" value="1">

    <fieldset class="row mb-3">
        <legend class="col-sm-3 col-form-label">
            <?= I18N::translate('NOTE update strategy') ?>
        </legend>

        <div class="col-sm-9">
            <?php foreach ($note_strategies as $value => $label) : ?>
                <div class="form-check">
                    <input
                        class="form-check-input"
                        id="default_note_strategy_<?= e($value) ?>"
                        name="default_note_strategy"
                        type="radio"
                        value="<?= e($value) ?>"
                        <?= $value === $default_note_strategy ? 'checked' : '' ?>
                    >

                    <label class="form-check-label" for="default_note_strategy_<?= e($value) ?>">
                        <?= e($label) ?>
                    </label>
                </div>
            <?php endforeach ?>
        </div>
    </fieldset>

    <div class="row mb-3">
        <label class="col-sm-3 col-form-label" for="tiny_mde">
            <?= I18N::translate('Use of TinyMDE as the editor for transcription notes') ?>
        </label>

        <div class="col-sm-9">
            <div class="form-check">
                <input
                        class="form-check-input"
                        id="tiny_mde"
                        name="tiny_mde"
                        type="checkbox"
                        value="enabled"
                        <?= $tiny_mde === 'enabled' ? 'checked' : '' ?>
                >
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <label class="col-sm-3 col-form-label" for="tagging_support">
            <?= I18N::translate('Should tagging be supported') ?>
        </label>

        <div class="col-sm-9">
            <div class="form-check">
                <input
                        class="form-check-input"
                        id="tagging_support"
                        name="tagging_support"
                        type="checkbox"
                        value="enabled"
                        <?= $tagging_support === 'enabled' ? 'checked' : '' ?>
                >
            </div>
        </div>
    </div>

    <div class="row mb-3" id="tag_value_container">
        <label class="col-sm-3 col-form-label" for="tag_value">
            <?= I18N::translate('Tag value for tagging all sources with at least one transcription') ?>
        </label>

        <div class="col-sm-9">
            <div class="input-group">
                <span class="input-group-text"><?= $tag_prefix ?></span>
                <input
                        class="form-control"
                        id="tag_value"
                        name="tag_value"
                        type="text"
                        value="<?= e($tag_value) ?>"
                        required
                >
            </div>

            <div class="form-text">
                <?= I18N::translate('Default') . ': ' . SourceTranscription::DEFAULT_TAG_VALUE ?>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-sm-9 offset-sm-3">
            <button class="btn btn-primary" type="submit">
                <?= I18N::translate('save') ?>
            </button>
        </div>
    </div>
</form>

<script>
    const taggingSupportCheckbox = document.getElementById('tagging_support');
    const tagValueInput = document.getElementById('tag_value');
    const tagValueContainer = document.getElementById('tag_value_container');
    const tagPrefixAddon = tagValueInput.closest('.input-group').querySelector('.input-group-text');

    function updateTaggingFields() {
        const isEnabled = taggingSupportCheckbox.checked;
        tagValueInput.disabled = !isEnabled;
        if (isEnabled) {
            tagValueContainer.classList.remove('text-muted');
            tagPrefixAddon.classList.remove('text-muted');
            tagValueInput.setAttribute('required', 'required');
        } else {
            tagValueContainer.classList.add('text-muted');
            tagPrefixAddon.classList.add('text-muted');
            tagValueInput.removeAttribute('required');
        }
    }

    taggingSupportCheckbox.addEventListener('change', updateTaggingFields);
    updateTaggingFields();
</script>
