$providerStatusBadge = static function (?string $status): string {
    return match ($status) {
        'success' => '<span class="badge bg-success">' . I18N::translate('successful') . '</span>',
        'failed' => '<span class="badge bg-danger">' . I18N::translate('failed') . '</span>',
        default => '<span class="badge bg-secondary">' . I18N::translate('not tested') . '</span>',
    };
};

$statusBadge = static function (bool $status): string {
    return $status
        ? '<span class="badge bg-success">' . I18N::translate('yes') . '</span>'
        : '<span class="badge bg-secondary">' . I18N::translate('no') . '</span>';
};

