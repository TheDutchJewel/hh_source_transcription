?>

<h2><?= e($title) ?></h2>

<form method="post" action="<?= e(route('source-transcription-store-manual', ['tree' => $tree->name()])) ?>">
    <?= csrf_field() ?>

    <div class="row mb-3">
        <label class="col-sm-3 col-form-label" for="title">
            <?= I18N::translate('Title') ?>
        </label>
        <div class="col-sm-9">
            <input class="form-control" id="title" name="title" type="text" required>
        </div>
    </div>

    <div class="row mb-3">
        <label class="col-sm-3 col-form-label" for="source_xref">
            <?= I18N::translate('Source') ?>
        </label>

        <div class="col-sm-9">
            <div class="input-group">
                <select
                        class="form-select tom-select"
                        id="source_xref"
                        name="source_xref"
                        data-wt-url="<?= e(route(TomSelectSource::class, ['tree' => $tree->name(), 'at' => '@'])) ?>"
                        data-wt-i18n-no-results="<?= e(I18N::translate('No results found')) ?>"
                        placeholder="<?= e(I18N::translate('Search for a source')) ?>"
                        required
                ></select>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <label class="col-sm-3 col-form-label" for="media_xref">
            <?= I18N::translate('Media object') ?>
        </label>

        <div class="col-sm-9">
            <select
                    class="form-select"
                    id="media_xref"
                    name="media_xref"
                    disabled
            >
                <option value=""><?= I18N::translate('Select a source first') ?></option>
            </select>

            <div class="form-text">
                <?= I18N::translate('Only media objects linked to the selected source are shown.') ?>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <label class="col-sm-3 col-form-label" for="primary_language_tag">
            <?= I18N::translate('Primary language') ?>
        </label>
        <div class="col-sm-9">
            <select class="form-select" id="primary_language_tag" name="primary_language_tag">
                <option value=""><?= I18N::translate('Language not specified') ?></option>
                <?php foreach (PrimaryLanguage::labels() as $value => $label) : ?>
                    <option value="<?= e($value) ?>"><?= e($label) ?> (<?= e($value) ?>)</option>
                <?php endforeach ?>
            </select>
        </div>
    </div>

    <div class="row mb-3">
        <label class="col-sm-3 col-form-label" for="primary_script_tag">
            <?= I18N::translate('Primary script') ?>
        </label>
        <div class="col-sm-9">
            <select class="form-select" id="primary_script_tag" name="primary_script_tag">
                <option value=""><?= I18N::translate('Script not specified') ?></option>
                <?php foreach (PrimaryScript::labels() as $value => $label) : ?>
                    <option value="<?= e($value) ?>"><?= e($label) ?> (<?= e($value) ?>)</option>
                <?php endforeach ?>
            </select>
        </div>
    </div>

    <div class="row mb-3">
        <label class="col-sm-3 col-form-label" for="primary_form">
            <?= I18N::translate('Primary form') ?>
        </label>
        <div class="col-sm-9">
            <select class="form-select" id="primary_form" name="primary_form">
                <option value=""><?= I18N::translate('Form not specified') ?></option>
                <?php foreach (PrimaryForm::labels() as $value => $label) : ?>
                    <option value="<?= e($value) ?>"><?= e($label) ?></option>
                <?php endforeach ?>
