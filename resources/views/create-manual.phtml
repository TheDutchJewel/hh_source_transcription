        <div class="col-sm-9">
            <textarea class="form-control" id="initial_note_text" name="initial_text" rows="10"></textarea>
        </div>
    </div>

    <button class="btn btn-primary" type="submit">
        <?= I18N::translate('Create transcription') ?>
    </button>
</form>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const sourceSelect = document.getElementById('source_xref');
        const mediaSelect = document.getElementById('media_xref');

        const mediaUrl = <?= json_encode(route(MediaForSourceAction::class, ['tree' => $tree->name()])) ?>;

        function resetMediaSelect(message) {
            mediaSelect.innerHTML = '';
            const option = document.createElement('option');
            option.value = '';
            option.textContent = message;
            mediaSelect.appendChild(option);
            mediaSelect.disabled = true;
        }

        function addMediaOption(value, label) {
            const option = document.createElement('option');
            option.value = value;
            option.textContent = label;
            mediaSelect.appendChild(option);
        }

        function loadMediaForSource(sourceXref) {
            sourceXref = (sourceXref || '').replaceAll('@', '').trim();

            if (!sourceXref) {
                resetMediaSelect(<?= json_encode(I18N::translate('Select a source first')) ?>);
                return;
            }

            resetMediaSelect(<?= json_encode(I18N::translate('Loading media objects…')) ?>);

            const separator = mediaUrl.includes('?') ? '&' : '?';

            fetch(mediaUrl + separator + 'source_xref=' + encodeURIComponent(sourceXref), {
                            headers: { 'Accept': 'application/json' }
            })
                .then(response => {
                    if (!response.ok) {
                        throw new Error('HTTP ' + response.status);
                    }
                    return response.json();
                })
                .then(items => {
                    mediaSelect.innerHTML = '';

                    if (!Array.isArray(items) || items.length === 0) {
                        resetMediaSelect(<?= json_encode(I18N::translate('No linked media objects found')) ?>);
                        return;
                    }

                    const emptyOption = document.createElement('option');
                    emptyOption.value = '';
                    emptyOption.textContent = <?= json_encode(I18N::translate('No media object selected')) ?>;
                    mediaSelect.appendChild(emptyOption);

                    for (const item of items) {
                        addMediaOption(item.id, item.text);
                    }

                    if (items.length === 1) {
                        mediaSelect.value = items[0].id;
                    }

                    mediaSelect.disabled = false;
                })
                .catch(error => {
                    console.error(error);
                    resetMediaSelect(<?= json_encode(I18N::translate('Could not load media objects')) ?>);
                });
        }

        sourceSelect.addEventListener('change', function () {
            loadMediaForSource(sourceSelect.value);
        });

        sourceSelect.addEventListener('input', function () {
            resetMediaSelect(<?= json_encode(I18N::translate('Select a source first')) ?>);
        });
    });
</script>