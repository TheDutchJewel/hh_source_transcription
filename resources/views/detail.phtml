declare(strict_types=1);

/**
 * @var string $title
 * @var Tree $tree
 * @var Transcription $transcription
 * @var array<int, TranscriptionRevision> $revisions
 * @var ?string $note_text
 * @var ?Source $source
 * @var ?Media $media_object
 * @var string $media_restriction
 * @var array<int, array{file: MediaFile, filename: string, title: string, form: string, type: string}> $media_files
 * @var array<int, mixed> $eligible_collaborators
 * @var array<int, array{name: string, role: string}> $active_collaborators
 * @var array<int, int> $active_collaborator_ids
 * @var bool $can_edit_note
 * @var bool $can_open_collaboration
 * @var bool $collaboration_is_editable
 * @var bool $can_submit_review
 * @var bool $can_finalize
 * @var bool $can_reopen
 * @var bool $is_internal_collaboration
 * @var bool $can_finalize_manual
 * @var bool $can_reopen_manual
 */

use Fisharebest\Webtrees\I18N;
use Fisharebest\Webtrees\Auth;
use Fisharebest\Webtrees\Media;
use Fisharebest\Webtrees\MediaFile;
use Fisharebest\Webtrees\Registry;
use Fisharebest\Webtrees\Source;
use Fisharebest\Webtrees\Tree;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\Entity\Transcription;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\Entity\TranscriptionRevision;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\Enum\PrimaryForm;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\Enum\PrimaryLanguage;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\Enum\PrimaryScript;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\ValueObject\ProviderPresentation;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\Enum\RevisionOriginType;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\Enum\TranscriptionStatus;

$note = null;
if ($transcription->current_note_xref !== null) {
    $note = Registry::noteFactory()->make($transcription->current_note_xref, $tree);
}

$badge_class = match (TranscriptionStatus::tryFrom($transcription->status)) {
    TranscriptionStatus::NEW              => 'bg-secondary',
    TranscriptionStatus::IN_PROGRESS      => 'bg-warning text-dark',
    TranscriptionStatus::READY_FOR_REVIEW => 'bg-info text-dark',
    TranscriptionStatus::FINAL            => 'bg-success',
    TranscriptionStatus::REOPENED         => 'bg-primary',
    TranscriptionStatus::CANCELED         => 'bg-light text-dark',
    null                                  => 'bg-light text-dark',
};

// formatting options - CSS class
$cell_format = 'text-decoration-none d-block';
$muted = 'text-secondary fst-italic';

$provider_label = ProviderPresentation::label($transcription->provider_key);
$provider_url   = ProviderPresentation::url($transcription->provider_key, $tree);
$provider_icon  = ProviderPresentation::icon($transcription->provider_key);
$provider_title = ProviderPresentation::title($transcription->provider_key);
?>

<h2><?= e($title) ?>: <?= e($transcription->title) ?></h2>

<p>
    <a class="btn btn-secondary" href="<?= e(route('source-transcription-dashboard', ['tree' => $tree->name()])) ?>">
        <?= I18N::translate('Back to dashboard') ?>
    </a>
</p>

<?php if ($can_edit_note && $transcription->current_note_xref !== null) : ?>
    <div class="alert alert-info">
        <?= I18N::translate('The current webtrees NOTE is used as a working copy. Changes are only archived when saved as a new revision.') ?>
    </div>
<?php endif ?>

<div class="card mb-3">
    <div class="card-header">
        <?= I18N::translate('Information') ?>
    </div>

    <div class="card-body">
        <div class="row">
            <div class="col-md-4">
                <table class="table table-sm table-borderless mb-0">
                    <tbody>
                        <tr>
                            <th style="width: 33%"><?= I18N::translate('Source') ?></th>
                            <td>
                                <?php if ($source) : ?>
                                    <a href="<?= e($source->url()) ?>">
                                        <?= $source->fullName() ?>
                                    </a>
                                <?php endif ?>
                            </td>
                        </tr>
                        <tr>
                            <th><?= I18N::plural('Media file', 'Media files', count($media_files)) ?></th>
                            <td>
                                <?php if ($media_object) : ?>
                                    <div>
                                        <?php if ($media_files === []) : ?>
                                            <a href="<?= e($media_object->url()) ?>" class="<?= $cell_format ?>">
                                                <?= $media_object->fullName() ?>
                                            </a>
                                        <?php endif ?>

                                        <?php foreach ($media_files as $index => $file_data) : ?>
                                            <div class="<?= $index === 0 ? '' : 'mt-2 pt-2 border-top' ?>">
                                                <a href="<?= e($media_object->url()) ?>" class="<?= $cell_format ?>">
                                                    <?= e($file_data['title'] !== '' ? $file_data['title'] : $file_data['filename']) ?>
                                                </a>
                                                <div class="small text-muted">
                                                    <div><strong>FILE:</strong> <?= e($file_data['filename']) ?></div>
                                                    <?php if ($file_data['form'] !== '') : ?>
                                                        <div><strong>FORM:</strong> <?= e($file_data['form']) ?></div>
                                                    <?php endif ?>
                                                    <?php if ($file_data['type'] !== '') : ?>
                                                        <div><strong>TYPE:</strong> <?= e($file_data['type']) ?></div>
                                                    <?php endif ?>
                                                </div>
                                            </div>
                                        <?php endforeach ?>
                                    </div>
                                    <?php if ($media_restriction !== '') : ?>
                                        <div class="small text-danger">
                                            <?= Registry::elementFactory()->make('OBJE:RESN')->labelValue($media_restriction, $tree) ?>
                                        </div>
                                    <?php endif ?>
                                <?php else : ?>
                                    <span class="<?= $muted ?>">
                                        <?= I18N::translate('No media object selected.') ?>
                                    </span>
                                <?php endif ?>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="col-md-4 border-start">
                <table class="table table-sm table-borderless mb-0">
                    <tbody>
                        <tr>
                            <th style="width: 33%"><?= I18N::translate('Provider') ?></th>
                            <td>
                                <a href="<?= e($provider_url) ?>" title="<?= e($provider_title) ?>" class="<?= $cell_format ?>">
                                    <?php if ($provider_icon !== '') : ?>
                                        <img src="<?= e($provider_icon) ?>" alt="" width="16" height="16" class="me-1">
                                    <?php endif ?>
                                    <?= e($provider_label) ?>
                                </a>
                            </td>
                        </tr>
                        <tr>
                            <th><?= I18N::translate('Status') ?></th>
                            <td>
                                <span class="badge <?= $badge_class ?>">
                                    <?= e(TranscriptionStatus::labels()[$transcription->status]) ?>
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <th><?= I18N::translate('Current NOTE') ?></th>
                            <td>
                                <?php if ($transcription->current_note_xref !== null && $note !== null) : ?>
                                    <a href="<?= e($note->url()) ?>" class="<?= $cell_format ?>">
                                        <?= $note->fullName() ?>
                                    </a>
                                <?php elseif ($transcription->current_note_xref !== null) : ?>
                                    <?= e($transcription->current_note_xref) ?>
                                <?php else : ?>
                                    <span class="<?= $muted ?>">
                                        <?= I18N::translate('None') ?>
                                    </span>
                                <?php endif ?>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="col-md-4 border-start">
                <table class="table table-sm table-borderless mb-0">
                    <tbody>
                        <tr>
                            <th style="width: 33%"><?= I18N::translate('Primary language') ?></th>
                            <td><?= e(PrimaryLanguage::label($transcription->primary_language_tag)) ?></td>
                        </tr>
                        <tr>
                            <th><?= I18N::translate('Primary script') ?></th>
                            <td><?= e(PrimaryScript::label($transcription->primary_script_tag)) ?></td>
                        </tr>
                        <tr>
                            <th><?= I18N::translate('Primary form') ?></th>
                            <td><?= e(PrimaryForm::label($transcription->primary_form)) ?></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">
        <?= I18N::translateContext('Panel heading for the webtrees-internal collaboration workflow', 'Internal collaboration') ?>
    </div>

    <div class="card-body">
        <?php if ($active_collaborators !== []) : ?>
            <div class="mb-3">
                <strong><?= I18N::translate('Team') ?></strong>
                <ul class="mb-0">
                    <?php foreach ($active_collaborators as $collaborator) : ?>
                        <li>
                            <?= e($collaborator['name']) ?>
                            <span class="text-muted">
                                (<?= e($collaborator['role'] === 'initiator' ? I18N::translateContext('Collaboration team role', 'Initiator') : I18N::translateContext('Collaboration team role, singular noun', 'Collaborator')) ?>)
                            </span>
                        </li>
                    <?php endforeach ?>
                </ul>
            </div>
        <?php elseif (!$can_open_collaboration) : ?>
            <div class="text-muted">
                <?= I18N::translate('This transcription is not currently open for internal collaboration.') ?>
            </div>
        <?php endif ?>

        <?php if ($is_internal_collaboration && ($can_submit_review || $can_finalize || $can_reopen)) : ?>
            <form method="post" action="<?= e(route('source-transcription-collaboration-status', ['tree' => $tree->name(), 'transcription_id' => $transcription->id])) ?>" class="mb-3 d-flex gap-2 flex-wrap">
                <?= csrf_field() ?>

                <?php if ($can_submit_review) : ?>
                    <button class="btn btn-info" type="submit" name="collaboration_action" value="submit_for_review">
                        <?= I18N::translateContext('Button: submit the transcription for review', 'Ready for review') ?>
                    </button>
                <?php endif ?>

                <?php if ($can_finalize) : ?>
                    <button class="btn btn-success" type="submit" name="collaboration_action" value="finalize">
                        <?= I18N::translateContext('Button: mark this transcription as final', 'Finalize') ?>
                    </button>
                <?php endif ?>

                <?php if ($can_reopen) : ?>
                    <button class="btn btn-warning" type="submit" name="collaboration_action" value="reopen">
                        <?= I18N::translateContext('Button: reopen this finalized transcription for editing', 'Reopen') ?>
                    </button>
                <?php endif ?>
            </form>
        <?php endif ?>

        <?php if (!$is_internal_collaboration && ($can_finalize_manual || $can_reopen_manual)) : ?>
            <form method="post" action="<?= e(route('source-transcription-manual-status', ['tree' => $tree->name(), 'transcription_id' => $transcription->id])) ?>" class="mb-3 d-flex gap-2 flex-wrap">
                <?= csrf_field() ?>

                <?php if ($can_finalize_manual) : ?>
                    <button class="btn btn-success" type="submit" name="manual_action" value="finalize">
                        <?= I18N::translateContext('Button: mark this transcription as final', 'Finalize') ?>
                    </button>
                <?php endif ?>

                <?php if ($can_reopen_manual) : ?>
                    <button class="btn btn-warning" type="submit" name="manual_action" value="reopen">
                        <?= I18N::translateContext('Button: reopen this finalized transcription for editing', 'Reopen') ?>
                    </button>
                <?php endif ?>
            </form>
        <?php endif ?>

        <?php if ($can_open_collaboration) : ?>
            <form method="post" action="<?= e(route('source-transcription-open-collaboration', ['tree' => $tree->name(), 'transcription_id' => $transcription->id])) ?>">
                <?= csrf_field() ?>

                <div class="row">
                    <div class="col-md-6">
                        <label class="form-label">
                            <?= I18N::translateContext('Form label for selecting multiple collaboration team members; not a plural variant of the role label', 'Collaborators') ?>
                        </label>

                        <?php if ($eligible_collaborators === []) : ?>
                            <div class="alert alert-secondary mb-0">
                                <?= I18N::translate('No eligible users found.') ?>
                            </div>
                        <?php else : ?>
                            <div class="border rounded p-2" style="max-height: 12rem; overflow-y: auto;">
                                <?php foreach ($eligible_collaborators as $candidate) : ?>
                                    <div class="form-check">
                                        <input
                                            class="form-check-input"
                                            type="checkbox"
                                            id="collaborator-<?= e((string) $candidate->id()) ?>"
                                            name="collaborator_user_ids[]"
                                            value="<?= e((string) $candidate->id()) ?>"
                                            <?= in_array($candidate->id(), $active_collaborator_ids, true) ? 'checked' : '' ?>
                                        >
                                        <label class="form-check-label" for="collaborator-<?= e((string) $candidate->id()) ?>">
                                            <?= e($candidate->realName() !== '' ? $candidate->realName() : $candidate->userName()) ?>
                                        </label>
                                    </div>
                                <?php endforeach ?>
                            </div>
                        <?php endif ?>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="collaboration-message">
                            <?= I18N::translate('Message') ?>
                        </label>
                        <textarea class="form-control" id="collaboration-message" name="message" rows="4"></textarea>

                        <div class="form-check mt-2">
                            <input class="form-check-input" type="checkbox" id="save-current-note-first" name="save_current_note_first" value="1" checked>
                            <label class="form-check-label" for="save-current-note-first">
                                <?= I18N::translate('Save the current NOTE as a starting revision') ?>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <button class="btn btn-primary" type="submit" <?= $eligible_collaborators === [] ? 'disabled' : '' ?>>
                        <?= $is_internal_collaboration ? I18N::translateContext('Button: update the selected collaboration team', 'Update collaboration') : I18N::translateContext('Button: open this transcription for collaboration', 'Open for collaboration') ?>
                    </button>
                </div>
            </form>
        <?php elseif (Auth::isEditor($tree) && !$collaboration_is_editable) : ?>
            <div class="text-muted">
                <?= I18N::translateContext('Hint shown when collaboration cannot be started because the transcription is final or canceled', 'Reopen the transcription before starting or changing internal collaboration.') ?>
            </div>
        <?php endif ?>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <?= I18N::translate('Media preview') ?>
            </div>

            <div class="card-body">
                <?php if ($media_object === null) : ?>
                    <div class="alert alert-secondary mb-0">
                        <?= I18N::translate('No media object selected.') ?>
                    </div>
                <?php elseif ($media_files === []) : ?>
                    <div class="alert alert-warning mb-0">
                        <?= I18N::translate('No media files found for this media object.') ?>
                    </div>
                <?php else : ?>
                <?php if (count($media_files) > 1) : ?>
                    <div class="mb-3">
                        <label class="form-label" for="media-file-select">
                            <?= I18N::translateContext('Label for selecting one media file', 'Media file') ?>
                        </label>

                        <select class="form-select" id="media-file-select">
                            <?php foreach ($media_files as $index => $file_data) : ?>
                                <option value="<?= e((string) $index) ?>">
                                    <?= e($file_data['filename']) ?>
                                </option>
                            <?php endforeach ?>
                        </select>
                    </div>
                <?php endif ?>

                <?php foreach ($media_files as $index => $file_data) : ?>
                    <?php $file = $file_data['file']; ?>
                    <div
                            class="source-transcription-media-preview"
                            data-media-file-index="<?= e((string) $index) ?>"
                            style="<?= $index === 0 ? '' : 'display:none' ?>"
                    >
                        <?php if ($file->isImage()) : ?>
                            <div class="border p-2 text-center">
                                <?= $file->displayImage(900, 900, 'contain', [
                                        'class' => 'img-fluid',
                                ]) ?>
                            </div>
                        <?php else : ?>
                            <div class="alert alert-secondary">
                                <?= I18N::translate('This media file cannot be previewed here.') ?>
                            </div>
                            <p>
                                <?= e($file_data['filename']) ?>
                            </p>
                        <?php endif ?>
                    </div>
                <?php endforeach ?>

                    <script>
                        document.addEventListener('DOMContentLoaded', function () {
                            const select = document.getElementById('media-file-select');

                            if (!select) {
                                return;
                            }

                            select.addEventListener('change', function () {
                                document.querySelectorAll('.source-transcription-media-preview').forEach(function (element) {
                                    element.style.display = element.dataset.mediaFileIndex === select.value ? '' : 'none';
                                });
                            });
                        });
                    </script>

                <?php endif ?>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <?= I18N::translate('Current NOTE') ?>
            </div>

            <div class="card-body">
                <?php if ($can_edit_note) : ?>
                    <form method="post" action="<?= e(route('source-transcription-update-note', ['tree' => $tree->name(), 'transcription_id' => $transcription->id])) ?>">
                        <?= csrf_field() ?>

                        <textarea
                            class="form-control font-monospace"
                            id="current_note_text"
                            name="note_text"
                            rows="24"
                        ><?= e((string) $note_text) ?></textarea>

                        <div class="mt-3 d-flex gap-2">
                            <button class="btn btn-primary" type="submit">
                                <?= I18N::translate('Save NOTE') ?>
                            </button>
                            <button class="btn btn-success" type="submit" formaction="<?= e(route('source-transcription-save-note-as-revision', ['tree' => $tree->name(), 'transcription_id' => $transcription->id])) ?>">
                                <?= I18N::translate('Archive as new revision') ?>
                            </button>
                        </div>
                    </form>
                <?php else : ?>
                    <div class="border p-2 bg-light font-monospace" style="white-space: pre-wrap; height: 500px; overflow-y: auto;">
                        <?= e((string) $note_text) ?>
                    </div>
                <?php endif ?>
            </div>
        </div>
    </div>
</div>

<hr>

<h3><?= I18N::translate('Revision history') ?></h3>

<table class="table table-bordered table-sm">
    <thead>
        <tr>
            <th><?= I18N::translate('Current') ?></th>
            <th><?= I18N::translate('Revision') ?></th>
            <th><?= I18N::translate('Origin') ?></th>
            <th><?= I18N::translate('Generated NOTE') ?></th>
            <th><?= I18N::translate('NOTE change') ?></th>
            <th><?= I18N::translate('Text') ?></th>
        </tr>
    </thead>

    <tbody>
        <?php foreach ($revisions as $revision) : ?>
            <tr>
                <td><?= $revision->is_current_revision ? '✓' : '' ?></td>
                <td><?= e((string) $revision->revision_no) ?></td>
                <td><?= e(RevisionOriginType::labels()[$revision->origin_type] ?? $revision->origin_type) ?></td>
                <td>
                    <?php if ($revision->generated_note_xref !== null) : ?>
                        <?php $revision_note = Registry::noteFactory()->make($revision->generated_note_xref, $tree); ?>
                        <?php if ($revision_note !== null) : ?>
                            <a href="<?= e($revision_note->url()) ?>">
                                <?= e($revision->generated_note_xref) ?>
                            </a>
                        <?php else : ?>
                            <?= e($revision->generated_note_xref) ?>
                        <?php endif ?>
                    <?php endif ?>
                </td>
                <td>
                    <?php if ($revision->generated_note_changed_by_user_name !== null) : ?>
                        <div><?= e($revision->generated_note_changed_by_user_name) ?></div>
                    <?php endif ?>
                    <?php if ($revision->generated_note_changed_at !== null) : ?>
                        <div class="text-muted small"><?= e($revision->generated_note_changed_at) ?></div>
                    <?php endif ?>
                </td>
                <td><pre class="mb-0"><?= e(mb_substr($revision->content_text, 0, 500)) ?></pre></td>
            </tr>
        <?php endforeach ?>
    </tbody>
</table>
