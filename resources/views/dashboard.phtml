// formatting options - CSS class
$cell_format = 'text-decoration-none d-block';
$muted = 'text-secondary fst-italic';

$dashboard_filters = $dashboard_filters ?? [];
$status_options = $status_options ?? [];
$provider_options = $provider_options ?? [];
$dashboard_url = route('source-transcription-dashboard', ['tree' => $tree->name()]);
$dashboard_form_action = $dashboard_url;
$dashboard_form_hidden = [];
$dashboard_form_query = parse_url($dashboard_url, PHP_URL_QUERY);

if ($dashboard_form_query !== null) {
    parse_str($dashboard_form_query, $dashboard_form_hidden);
    $dashboard_form_action = strtok($dashboard_url, '?') ?: $dashboard_url;
}

$current_sort = (string)($dashboard_filters['sort'] ?? 'created');
$current_direction = (string)($dashboard_filters['direction'] ?? 'desc');
$current_status = ($dashboard_filters['status'] ?? null) !== null ? (string)$dashboard_filters['status'] : '';
$current_provider = ($dashboard_filters['provider'] ?? null) !== null ? (string)$dashboard_filters['provider'] : '';
$current_page = (int)($dashboard_filters['page'] ?? 1);
$total_pages = (int)($dashboard_filters['total_pages'] ?? 1);
$total_transcriptions = (int)($dashboard_filters['total'] ?? count($transcriptions));
$per_page = (int)($dashboard_filters['per_page'] ?? 20);
$first_item = $total_transcriptions > 0 ? (($current_page - 1) * $per_page) + 1 : 0;
$last_item = $total_transcriptions > 0 ? min($total_transcriptions, $current_page * $per_page) : 0;

$url_for = static function (array $overrides = []) use ($tree, $current_sort, $current_direction, $current_status, $current_provider, $current_page): string {
    $query = array_merge([
        'tree'      => $tree->name(),
        'sort'      => $current_sort,
        'direction' => $current_direction,
        'status'    => $current_status,
        'provider'  => $current_provider,
        'page'      => $current_page,
    ], $overrides);

    $query = array_filter($query, static fn ($value): bool => $value !== null && $value !== '' && $value !== 1);

    return route('source-transcription-dashboard', $query);
};

$sort_url = static function (string $sort) use ($url_for, $current_sort, $current_direction): string {
    $default_direction = in_array($sort, ['created', 'updated'], true) ? 'desc' : 'asc';
    $direction = $current_sort === $sort && $current_direction === 'asc' ? 'desc' : $default_direction;

    return $url_for([
        'sort'      => $sort,
        'direction' => $direction,
        'page'      => 1,
    ]);
};

$sort_indicator = static function (string $sort) use ($current_sort, $current_direction): string {
    if ($current_sort !== $sort) {
        return '';
    }

    return $current_direction === 'asc'
        ? ' <span aria-hidden="true">&uarr;</span>'
        : ' <span aria-hidden="true">&darr;</span>';
};

$format_timestamp = static function (?string $timestamp) use ($muted): string {
    if ($timestamp === null || $timestamp === '') {
        return '<span class="' . $muted . '">' . e(I18N::translate('None')) . '</span>';
    }

    $parsed_timestamp = DateTimeImmutable::createFromFormat('Y-m-d H:i:s', $timestamp, new DateTimeZone('UTC'));

    if ($parsed_timestamp === false) {
        $parsed_timestamp = DateTimeImmutable::createFromFormat('Y-m-d H:i', $timestamp, new DateTimeZone('UTC'));
    }

    if ($parsed_timestamp === false) {
        return e($timestamp);
    }

    $localized_timestamp = new Timestamp(
        $parsed_timestamp->getTimestamp(),
        Site::getPreference('TIMEZONE'),
        I18N::locale()->code()
    );

    return '<time datetime="' . e($localized_timestamp->toDateTimeString()) . '" title="' . e($localized_timestamp->isoFormat('LLLL')) . '" dir="auto">' .
        e($localized_timestamp->isoFormat('L LT')) .
        '</time>';
};
?>

