declare(strict_types=1);

/**
 * @var string $title
 * @var Tree $tree
 * @var array<int, Transcription> $transcriptions
 * @var array<int, object> $transkribus_jobs
 * @var array<int, array<int, object>> $transkribus_job_files
 * @var bool $discourse_authorized
 * @var array<string,string> $discourse_settings
 * @var string|null $discourse_last_test_status
 * @var string|null $discourse_last_test_message
 */

use Fisharebest\Webtrees\I18N;
use Fisharebest\Webtrees\Auth;
use Fisharebest\Webtrees\Registry;
use Fisharebest\Webtrees\Tree;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\Entity\Transcription;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\Enum\TranskribusJobFileStatus;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\Enum\TranskribusJobStatus;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\ValueObject\ProviderPresentation;
use Hartenthaler\Webtrees\Module\SourceTranscription\Domain\Enum\TranscriptionStatus;
use Hartenthaler\Webtrees\Module\SourceTranscription\Support\TranscriptionSlug;

// formatting options - CSS class
$cell_format = 'text-decoration-none d-block';
$muted = 'text-secondary fst-italic';
?>

<h2 class="mb-3"><?= e($title) ?></h2>

<?php if (Auth::isEditor($tree)) : ?>
<p class="d-flex gap-2 mb-5 flex-wrap">
    <a class="btn btn-primary" href="<?= e(route('source-transcription-create-manual', ['tree' => $tree->name()])) ?>">
        <?= I18N::translate('Create manual transcription') ?>
    </a>
    <a class="btn btn-primary" href="<?= e(route('source-transcription-create-transkribus', ['tree' => $tree->name()])) ?>">
        <?= I18N::translate('Upload images to Transkribus') ?>
    </a>
    <a class="btn btn-secondary" href="<?= e(route('source-transcription-authorize-discourse', ['tree' => $tree->name(), 'base_url' => 'https://discourse.genealogy.net'])) ?>">
        <?= $discourse_authorized ? I18N::translate('Renew Discourse authorization') : I18N::translate('Authorize Discourse') ?>
    </a>
    <a class="btn btn-outline-secondary" href="<?= e(route('source-transcription-authorize-discourse', ['tree' => $tree->name(), 'base_url' => 'https://discourse-test.genealogy.net'])) ?>">
        <?= I18N::translate('Authorize Discourse test') ?>
    </a>
</p>
<?php if ($discourse_authorized) : ?>
    <p class="text-muted small">
        <?= I18N::translate('Discourse authorization stored for %s.', e($discourse_settings['base_url'] ?? 'Discourse')) ?>
        <?php if ($discourse_last_test_status !== null && $discourse_last_test_message !== null) : ?>
            <?= e($discourse_last_test_message) ?>
        <?php endif ?>
    </p>
<?php endif ?>
<?php endif ?>

<?php if (($transkribus_jobs ?? []) !== []) : ?>
    <section class="mb-5">
    <h3 class="mb-3"><?= I18N::translate('Transkribus jobs') ?></h3>

    <table class="table table-bordered table-sm mb-0">
        <thead>
            <tr>
                <th><?= I18N::translate('Job title') ?></th>
                <th><?= I18N::translate('Source') ?></th>
                <th><?= I18N::translate('Media') ?></th>
                <th><?= I18N::translate('Status') ?></th>
                <th><?= I18N::translate('Upload references') ?></th>
                <th><?= I18N::translate('Message') ?></th>
            </tr>
        </thead>
        <tbody>
            <?php foreach ($transkribus_jobs as $job) : ?>
                <?php
                $source = Registry::sourceFactory()->make((string) $job->source_xref, $tree);
                $media = Registry::mediaFactory()->make((string) $job->media_xref, $tree);
                $job_badge_class = match (TranskribusJobStatus::tryFrom((string) $job->status)) {
                    TranskribusJobStatus::UPLOADED      => 'bg-success',
                    TranskribusJobStatus::UPLOADING     => 'bg-warning text-dark',
                    TranskribusJobStatus::UPLOAD_FAILED => 'bg-danger',
                    null                                => 'bg-secondary',
                };
                ?>
                <tr>
                    <td>
                        #<?= e((string) $job->id) ?>
                        <?= e((string) $job->title) ?>
                    </td>
                    <td>
                        <?php if ($source !== null) : ?>
                            <a href="<?= e($source->url()) ?>"><?= $source->fullName() ?></a>
                        <?php else : ?>
                            <span class="<?= $muted ?>"><?= I18N::translate('Deleted') ?></span>
                        <?php endif ?>
                    </td>
                    <td>
                        <?php if ($media !== null) : ?>
                            <a href="<?= e($media->url()) ?>"><?= $media->fullName() ?></a>
                        <?php else : ?>
                            <span class="<?= $muted ?>"><?= I18N::translate('Deleted') ?></span>
                        <?php endif ?>
                    </td>
                    <td>
                        <span class="badge <?= $job_badge_class ?>">
                            <?= e(TranskribusJobStatus::label((string) $job->status)) ?>
                        </span>
                    </td>
                    <td>
                        <?php foreach (($transkribus_job_files[(int) $job->id] ?? []) as $file) : ?>
                            <?php $file_message = trim((string) ($file->message ?? '')) ?>
                            <div class="small">
                                <?= e((string) $file->filename) ?>:
                                <?php if ($file->upload_reference !== null && $file->upload_reference !== '') : ?>
                                    <code><?= e((string) $file->upload_reference) ?></code>
                                <?php else : ?>
                                    <span class="<?= $muted ?>"><?= e(TranskribusJobFileStatus::label((string) $file->status)) ?></span>
                                <?php endif ?>
                                <?php if ($file_message !== '') : ?>
                                    <div class="text-danger"><?= e($file_message) ?></div>
                                <?php endif ?>
                            </div>
                        <?php endforeach ?>
                    </td>
                    <td><?= e((string) ($job->last_message ?? '')) ?></td>
                </tr>
            <?php endforeach ?>
        </tbody>
    </table>
    </section>
<?php endif ?>

<?php if (count($transcriptions) > 0) : ?>
    <section class="mt-5">
    <h3 class="mb-3"><?= I18N::translate('Transcriptions') ?></h3>
<?php endif ?>

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        <!-- später: Suche / Filter -->
    </div>

    <div>
        <?php if (count($transcriptions) > 0) : ?>
            <span class="badge bg-secondary">
                <?= I18N::plural('%s transcription', '%s transcriptions', count($transcriptions), I18N::number(count($transcriptions))) ?>
            </span>
        <?php endif ?>
    </div>
</div>

<?php if (count($transcriptions) > 0) : ?>
    <table class="table table-bordered table-sm">
        <thead>
        <tr>
            <th><?= I18N::translate('Transcription title') ?></th>
            <th><?= I18N::translate('Source') ?></th>
            <th><?= I18N::translate('Media') ?></th>
            <th><?= I18N::translate('Transcription provider') ?></th>
            <th><?= I18N::translate('Status') ?></th>
            <th><?= I18N::translate('Note') ?></th>
            <th><?= I18N::translate('Actions') ?></th>
        </tr>
        </thead>
        <tbody>
        <?php foreach ($transcriptions as $transcription) : ?>
            <?php
            $source = Registry::sourceFactory()->make($transcription->source_xref, $tree);

            $detail_url = route('source-transcription-detail', [
                    'tree'             => $tree->name(),
                    'transcription_id' => $transcription->id,
                    'slug'             => TranscriptionSlug::fromTitle($transcription->title),
            ]);

            $action_url = route('source-transcription-detail', [
                    'tree'             => $tree->name(),
                    'transcription_id' => $transcription->id,
            ]);

            $provider_label = ProviderPresentation::label($transcription->provider_key);
            $provider_url   = ProviderPresentation::url($transcription->provider_key, $tree);
            $provider_icon  = ProviderPresentation::icon($transcription->provider_key);
            $provider_title = ProviderPresentation::title($transcription->provider_key);

            $media = null;
            if ($transcription->media_xref !== null) {
                $media = Registry::mediaFactory()->make($transcription->media_xref, $tree);
            }

            $note = null;
            if ($transcription->current_note_xref !== null) {
                $note = Registry::noteFactory()->make($transcription->current_note_xref, $tree);
            }

            $badge_class = match (TranscriptionStatus::tryFrom($transcription->status)) {
                TranscriptionStatus::NEW              => 'bg-secondary',
                TranscriptionStatus::IN_PROGRESS      => 'bg-warning text-dark',
                TranscriptionStatus::READY_FOR_REVIEW => 'bg-info text-dark',
                TranscriptionStatus::FINAL            => 'bg-success',
                TranscriptionStatus::REOPENED         => 'bg-primary',
                TranscriptionStatus::CANCELED         => 'bg-light text-dark',
                null                                  => 'bg-light text-dark',
            };
            ?>

            <tr class="align-top">
                <td>
                    <a href="<?= e($detail_url) ?>">
                        <?= e($transcription->title) ?>
                    </a>
                </td>
                <td>
                    <?php if ($source !== null) : ?>
                        <a href="<?= e($source->url()) ?>" class="<?= $cell_format ?>">
                            <?= $source->fullName() ?: I18N::translate('Source record') ?>
                        </a>
                    <?php else : ?>
                        <span class="<?= $muted ?>">
                            <?= e(I18N::translate('Deleted')) ?>
                        </span>
                    <?php endif ?>
                </td>
                <td>
                    <?php if ($media !== null) : ?>
                        <?php $media_files = $media->mediaFiles() ?>
                        <?php if ($media_files->isEmpty()) : ?>
                            <a href="<?= e($media->url()) ?>" class="<?= $cell_format ?>">
                                <?= $media->fullName() ?: I18N::translate('Media object') ?>
                            </a>
                        <?php endif ?>

                        <?php foreach ($media_files as $media_file) : ?>
                            <div class="d-flex align-items-start gap-2 mb-1">
                                <div class="text-center" style="width: 30px;">
                                    <?php if ($media_file->isExternal()) : ?>
                                        <span class="fs-5 text-muted" title="<?= e(I18N::translate('External media URL')) ?>">
                                            <?= view('icons/media') ?>
                                        </span>
                                    <?php else : ?>
                                        <?= $media_file->displayImage(30, 60, 'contain', []) ?>
                                    <?php endif ?>
                                </div>
                                <div>
                                    <a href="<?= e($media->url()) ?>" class="<?= $cell_format ?>">
                                        <?= e($media_file->title() !== '' ? $media_file->title() : $media_file->filename()) ?>
                                    </a>
                                </div>
                            </div>
                        <?php endforeach ?>
                    <?php else : ?>
                        <span class="<?= $muted ?>">
                            <?= e(I18N::translate('None')) ?>
                        </span>
                    <?php endif ?>
                </td>
                <td>
                    <a href="<?= e($provider_url) ?>" title="<?= e($provider_title) ?>" class="<?= $cell_format ?>">
                        <?php if ($provider_icon !== '') : ?>
                            <img src="<?= e($provider_icon) ?>" alt="" width="16" height="16" class="me-1">
                        <?php endif ?>
                        <?= e($provider_label) ?>
                    </a>
                </td>
                <td>
                    <span class="badge <?= $badge_class ?>">
                        <?= e(TranscriptionStatus::labels()[$transcription->status]) ?>
                    </span>
                </td>
                <td>
                    <?php if ($note !== null) : ?>
                        <a href="<?= e($note->url()) ?>" class="<?= $cell_format ?>">
                            <?= $note->fullName() ?>
                        </a>
                    <?php else : ?>
                        <span class="<?= $muted ?>">
                            <?= e(I18N::translate('None')) ?>
                        </span>
                    <?php endif ?>
                </td>
                <td>
                    <a class="btn btn-sm btn-secondary" href="<?= e($action_url) ?>">
                        <?= I18N::translate('Open') ?>
                    </a>
                </td>
            </tr>
        <?php endforeach ?>
        </tbody>
    </table>
    </section>
<?php endif ?>
